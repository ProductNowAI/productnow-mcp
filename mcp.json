{
  "$schema": "https://modelcontextprotocol.io/schemas/draft/mcp-server-metadata.json",
  "assets": {
    "icon": "assets/productnow-icon.png",
    "logo": "assets/productnow-logo.png"
  },
  "authentication": {
    "authorizationServerMetadataUrl": "https://api.productnow-prod.com/.well-known/oauth-authorization-server",
    "protectedResourceMetadataUrl": "https://api.productnow-prod.com/.well-known/oauth-protected-resource",
    "provider": "Auth0",
    "requiredScopes": ["mcp:use"],
    "type": "oauth2"
