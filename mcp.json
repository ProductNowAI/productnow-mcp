  "maintainers": [
    {
      "email": "support@productnow.ai"
    }
  ],
  "name": "ai.productnow/productnow",
  "title": "ProductNow",
  "transport": {
    "type": "streamable-http",
    "url": "https://api.productnow-prod.com/mcp"
  },
  "urls": {
    "app": "https://app.productnow.ai",
    "mcpEndpoint": "https://api.productnow-prod.com/mcp",
    "privacyPolicy": "https://app.productnow.ai/public/doc/roaq-bchj-dnsm",
    "termsOfService": "https://app.productnow.ai/public/doc/zqwd-nnqa-uflp",
    "website": "https://productnow.ai"
  },
  "version": "1.0.0"
